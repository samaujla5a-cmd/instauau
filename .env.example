# ════════════════════════════════════════════════════════
#  RAILWAY ENVIRONMENT VARIABLES
#  Copy these into Railway → your project → Variables tab
# ════════════════════════════════════════════════════════

# ─── kie.ai (REQUIRED — music + model video) ─────────────
# Sign up FREE at https://kie.ai (5000 credits, no card needed)
# Dashboard → API Keys → copy key
KIE_API_KEY=

# ─── AI Text Keys (for lyrics + captions) ────────────────
# Get free at console.groq.com (14,400 req/day)
GROQ_API_KEY=
# Get free at aistudio.google.com
GOOGLE_API_KEY=
GOOGLE_API_KEY_2=

# ─── RAP CHANNEL ─────────────────────────────────────────
RAP_IG_TOKEN=IGAAe...your_token_here
RAP_IG_USER_ID=          # REQUIRED: your Instagram Business account numeric ID

# ─── BRAINROT CHANNEL ────────────────────────────────────
BRAINROT_IG_TOKEN=IGAAe...your_token_here
BRAINROT_IG_USER_ID=     # REQUIRED: your Instagram Business account numeric ID

# ─── AI MODEL CHANNEL ────────────────────────────────────
MODEL_IG_TOKEN=IGAAe...your_token_here
MODEL_IG_USER_ID=        # REQUIRED: your Instagram Business account numeric ID

# ─── Telegram Notifications (optional) ───────────────────
# 1. Message @BotFather → /newbot → copy token
# 2. Message your bot once ("hi")
# 3. Bot prints your CHAT_ID in logs on first run
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── DO NOT CHANGE THESE ─────────────────────────────────
MUSIC_MODE=kie_suno
TTS_MODE=edge_tts

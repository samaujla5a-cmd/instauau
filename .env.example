RAP_IG_TOKEN=IGAAe...your_token_here
RAP_IG_USER_ID=26289756050724249

# ─── BRAINROT CHANNEL (@high4x5) ─────────────────────────
BRAINROT_IG_TOKEN=IGAAe...your_token_here
BRAINROT_IG_USER_ID=27577862725154087


# ════════════════════════════════════════════════════════
#  RAILWAY ENVIRONMENT VARIABLES
#  Copy these into Railway → your project → Variables tab
# ════════════════════════════════════════════════════════

# Anthropic AI (required for lyrics generation)
# ─── AI Keys ─────────────────────────────────────────
GROQ_API_KEY=          # REQUIRED — free at console.groq.com (primary AI)
ANTHROPIC_API_KEY=sk-ant-...

# ─── RAP CHANNEL (@xrap5r) ───────────────────────────────
RAP_IG_TOKEN=IGAAe...your_token_here
RAP_IG_USER_ID=26289756050724249

# ─── BRAINROT CHANNEL (@high4x5) ─────────────────────────
BRAINROT_IG_TOKEN=IGAAe...your_token_here
BRAINROT_IG_USER_ID=27577862725154087

# ─── AI MODEL CHANNEL (@saraofatr) ───────────────────────
MODEL_IG_TOKEN=IGAAe...your_token_here
MODEL_IG_USER_ID=26616509901340408

# ─── Optional settings ───────────────────────────────────
MUSIC_MODE=gtts_only
TTS_MODE=edge_tts
TTSAI_API_KEY=         # Get free key at tts.ai for better voice quality

# ─── Telegram Notifications ──────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Message your new bot once (say "hi")
# 3. Start the bot — it will print your CHAT_ID in the logs
TELEGRAM_BOT_TOKEN=    # e.g. 7123456789:AAFabc...
TELEGRAM_CHAT_ID=      # e.g. 123456789  (printed on first run)

# ─── IMPORTANT: Token Expiry ─────────────────────────────
# Tokens expire every 60 days.
# The master scheduler auto-refreshes them monthly.
# If a token expires manually, regenerate it at:
# developers.facebook.com → your app → API setup with Instagram login
